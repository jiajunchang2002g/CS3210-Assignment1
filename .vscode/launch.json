            "request": "launch",
            "program": "${workspaceFolder}/sim.debug",
            "args": [],
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "preLaunchTask": "",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set Disassembly Flavor to Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                }
            ],
            "console": "integratedTerminal",
            "logging": {
                "engineLogging": false
            },
            "sourceFileMap": {},
            "stdin": "${workspaceFolder}/inputs/in_debug_10"
        },
